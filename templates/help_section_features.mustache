        <marker id="as-arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
            <polygon points="0 0, 10 3.5, 0 7" fill="#6c757d"/>
        </marker>
    </defs>

    <ellipse cx="100" cy="140" rx="80" ry="40" class="as-clean"/>
    <text x="100" y="138" text-anchor="middle" class="as-text">CLEAN</text>
    <text x="100" y="156" text-anchor="middle" class="as-label">snapshot matches</text>

    <ellipse cx="320" cy="140" rx="80" ry="40" class="as-dirty"/>
    <text x="320" y="138" text-anchor="middle" class="as-text">DIRTY</text>
    <text x="320" y="156" text-anchor="middle" class="as-label">debounce timer running</text>

    <ellipse cx="560" cy="140" rx="80" ry="40" class="as-flight"/>
    <text x="560" y="138" text-anchor="middle" class="as-text">IN FLIGHT</text>
    <text x="560" y="156" text-anchor="middle" class="as-label">AJAX dispatched</text>

    <ellipse cx="560" cy="40" rx="80" ry="30" class="as-error"/>
    <text x="560" y="36" text-anchor="middle" class="as-text">RETRY QUEUED</text>
    <text x="560" y="52" text-anchor="middle" class="as-label">offline / 5xx</text>

    <ellipse cx="720" cy="240" rx="60" ry="30" class="as-clean"/>
    <text x="720" y="238" text-anchor="middle" class="as-text">CLEAN</text>
    <text x="720" y="254" text-anchor="middle" class="as-label">snapshot updated</text>

    <path d="M180 140 L240 140" class="as-arrow" marker-end="url(#as-arrowhead)"/>
    <text x="190" y="130" class="as-label">user edits</text>

    <path d="M400 140 L480 140" class="as-arrow" marker-end="url(#as-arrowhead)"/>
    <text x="410" y="130" class="as-label">focusout · 1.5s</text>

    <path d="M560 100 L560 70" class="as-arrow" marker-end="url(#as-arrowhead)"/>
    <text x="570" y="90" class="as-label">network err</text>

    <path d="M620 60 Q700 60 700 140 Q700 160 640 160" class="as-arrow" marker-end="url(#as-arrowhead)"/>
    <text x="650" y="100" class="as-label">SaveQueue retries</text>

    <path d="M620 170 Q680 200 700 215" class="as-arrow" marker-end="url(#as-arrowhead)"/>
    <text x="630" y="200" class="as-label">200 OK</text>

    <path d="M660 240 Q400 240 320 180" class="as-arrow" marker-end="url(#as-arrowhead)"/>
    <text x="380" y="230" class="as-label">_renderGuide reconciles, _saveInFlight=false</text>

    <path d="M180 130 Q200 90 300 100 L320 100" class="as-arrow" marker-end="url(#as-arrowhead)"/>
    <text x="190" y="80" class="as-label">edits during in-flight save: stay dirty</text>
</svg>
<figcaption class="text-muted small">Auto-save lifecycle. Edits during the in-flight window stay dirty so
the next focusout flushes them; failed network requests park in
<code>SaveQueue</code> and retry until success.</figcaption>
</figure>
</section>

{{! ----- i18n ----- }}
<section id="feature-i18n">
<h3>Languages</h3>

<p>The plugin ships with full translations for: Afrikaans, German, Greek,
Spanish, French, Hebrew, Italian, Portuguese, Russian, Swahili, Xhosa,
Zulu — alongside English. Set the language via Moodle's standard user /
site language preferences.</p>

<p>Strings used by client-side code are loaded via the standard
<code>core/str</code> module rather than hard-coded; a missing translation
falls back to English without breaking the UI.</p>
</section>
